# AIDA (Artificial Intelligence Defense Architect) Environment Configuration
# Ushbu fayldagi o'zgaruvchilarni .env fayliga nusxalang va haqiqiy qiymatlarni qo'ying.

# AIDA provider mode
# `local`   -> mustaqil local core (tashqi modelsiz).
# `lmstudio`-> LM Studio lokal serveri (OpenAI-mos endpoint).
# `remote`  -> Google Gemini API.
AIDA_PROVIDER=local

# Provider model (local/remote rejim uchun)
AIDA_MODEL=AIDA Local Core

# Tashqi provider ishlatilsa kerak bo'ladigan API key (remote/Gemini uchun)
AIDA_API_KEY=your_gemini_api_key_here

# LM Studio sozlamalari (AIDA_PROVIDER=lmstudio bo'lganda ishlatiladi)
# LM Studio'da "Local Server" yoqilgan bo'lishi kerak (default port 1234).
AIDA_LMSTUDIO_URL=http://localhost:1234/v1
# Yuklangan model nomi. LM Studio odatda istalgan qiymatni qabul qiladi.
AIDA_LMSTUDIO_MODEL=local-model
# LM Studio API key talab qilmaydi; istalgan qiymat ishlaydi.
AIDA_LMSTUDIO_API_KEY=lm-studio
# Lokal model sekin bo'lishi mumkin; kutish vaqti millisekundlarda.
AIDA_LLM_TIMEOUT_MS=120000

# Deploy uchun
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8070
DJANGO_SECURE_PROXY_SSL_HEADER=false
