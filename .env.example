# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Local backend/API port for AIDA memory and learning services.
AIDA_API_PORT="8787"

# JSON file used by the persistent memory service.
AIDA_MEMORY_FILE="data/aida-memory.json"

# Enables background learning on the backend.
AIDA_AUTO_LEARN="false"

# `true` bo'lsa AIDA tashqi LLMsiz, to'liq lokal/offline mantiq bilan ishlaydi.
AIDA_OFFLINE_ONLY="true"

# `true` bo'lsa AIDA internetdan ochiq manbalarni qidirib, xotiraga yozadi.
AIDA_ALLOW_WEB_RESEARCH="true"

# Learning interval in minutes when auto-learn is enabled.
AIDA_AUTO_LEARN_INTERVAL_MINUTES="60"

# Comma-separated safe topics for continuous learning.
AIDA_AUTO_LEARN_TOPICS="suniy intellekt,matematika,tarix,psixologiya,kiberxavfsizlik"

# Timeout for internet qidiruvi va lokal model so'rovlari uchun millisekundlarda.
AIDA_LLM_TIMEOUT_MS="20000"

# Ixtiyoriy: lokal Ollama modeli bo'lsa API keysiz yanada tabiiy javoblar uchun ishlatiladi.
# Misol: qwen2.5:7b, llama3.1:8b, mistral:7b
AIDA_OLLAMA_MODEL=""

# Ixtiyoriy: Ollama lokal server manzili.
AIDA_OLLAMA_URL="http://127.0.0.1:11434"
