# AIDA (Artificial Intelligence Defense Architect) Environment Configuration
# Ushbu fayldagi o'zgaruvchilarni .env fayliga nusxalang va haqiqiy qiymatlarni qo'ying.

# AIDA provider mode
# `local` default holat. Agar Ollama ishlayotgan bo'lsa, AIDA avtomatik unga ulanadi.
# Majburiy Ollama rejimi uchun `ollama`, tashqi provider uchun `remote` ishlating.
AIDA_PROVIDER=local

# Provider model
AIDA_MODEL=AIDA Local Core

# Ollama lokal serveri
AIDA_API_URL=http://localhost:11434
AIDA_OLLAMA_AUTOSTART=true

# Tashqi provider ishlatilsa kerak bo'ladigan API key
AIDA_API_KEY=your_gemini_api_key_here

# Deploy uchun
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8070
DJANGO_SECURE_PROXY_SSL_HEADER=false
