# AIDA (Artificial Intelligence Defense Architect) Environment Configuration
# Ushbu fayldagi o'zgaruvchilarni .env fayliga nusxalang va haqiqiy qiymatlarni qo'ying.

# AIDA provider mode
# `local` default holat. AIDA mustaqil local core sifatida ishlaydi.
# `ollama` - Ollama bilan ishlash uchun
# `collab` - Ollama va LM Studio hamkorlik rejimi
# `remote` - Tashqi API (Gemini)
# `lmstudio` - LM Studio bilan ishlash
# aida-beta - AIDA custom model (qwen2.5:3b asosida, AIDA shaxsiyati bilan)
# Foydalanish uchun: AIDA_PROVIDER=aida-beta
AIDA_PROVIDER=local

# Provider model
# "AIDA Local Core" - avtomatik model tanlash
# Yoki aniq model nomi: "qwen2.5:7b", "llama3:8b", va h.k.
AIDA_MODEL=AIDA Local Core

# Tashqi provider ishlatilsa kerak bo'ladigan API key
AIDA_API_KEY=your_gemini_api_key_here

# Ollama server URL (default: http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# Multi-Model System Configuration
# Enable intelligent model selection based on task type
MULTI_MODEL_ENABLED=true

# GPU Optimization Settings
# Quantization: "4bit", "8bit", or "none"
OLLAMA_QUANTIZATION=4bit

# Batch size for processing
OLLAMA_NUM_BATCH=512

# GPU usage: -1 (all GPUs), 0 (CPU only), or specific GPU number
OLLAMA_NUM_GPU=-1

# Number of CPU threads
OLLAMA_NUM_THREAD=8

# Model-specific configurations (optional)
# Override default model for specific task types
MODEL_CODE=codellama:34b
MODEL_PLAN=llama2:13b
MODEL_FAST=mistral:7b
MODEL_LIGHTWEIGHT=gemma:7b
MODEL_GENERAL=qwen2.5:7b

# Deploy uchun
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8070
DJANGO_SECURE_PROXY_SSL_HEADER=false
